BETTER_AUTH_SECRET=fg1GJar8g0eGXk79+kCm4vc6KvqVc/CRkfW3+C+QPOI=
BETTER_AUTH_API_KEY=ba_9e25ba99e00d4f0cb64b945bd3c99c56
BETTER_AUTH_URL=https://cafeteriahub.com
BETTER_AUTH_BASE_PATH=/api/auth
